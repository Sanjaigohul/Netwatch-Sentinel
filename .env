# ============================================================
#  NIDS Sentinel .env Configuration
#  COPY THIS FILE TO .env and fill in your values
#  cp .env.example .env
# ============================================================

# Flask secret key (change in production)
SECRET_KEY=nids-ultra-secret-2024

# ── MySQL Database ─────────────────────────────────────────
# Fill in YOUR MySQL credentials:
DB_HOST=localhost
DB_PORT=3306
DB_NAME=nids_db
DB_USER=root
DB_PASSWORD=Sanjaigohul@9325

# ── Capture mode ───────────────────────────────────────────
# True = simulation (default, no root needed)
# False = live network capture (requires sudo/admin)
SIMULATION_MODE=True

# Network interface for live capture (empty = auto-detect)
# Windows example: NETWORK_INTERFACE=Ethernet
# Linux example:   NETWORK_INTERFACE=eth0
# NETWORK_INTERFACE=

# ── Qwen AI Analysis ───────────────────────────────────────
# Get key from: https://openrouter.ai/
QWEN_API_KEY=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
QWEN_MODEL=qwen/qwen2.5-coder-32b-instruct
QWEN_BASE_URL=https://integrate.api.nvidia.com/v1

# ── Detection tuning (optional) ────────────────────────────
IF_CONTAMINATION=0.02
WINDOW_SIZE=10
